{
  "name": "nic-cage-snacks-shop",
  "private": true,
  "version": "3.0.0",
  "description": "Nic Cage Snacks Shop — Firebase web shop (Elli & Dany)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "legacy:original": "python3 -m http.server 5174 --directory legacy/original-2023",
    "seed:firebase": "node scripts/seed-firebase.mjs",
    "seed:firebase:legacy": "node scripts/seed-firebase.mjs https://nic-cage-snacks-legacy-default-rtdb.firebaseio.com/.json",
    "firebase:rules": "firebase deploy --only database",
    "firebase:rules:legacy": "firebase deploy --only database --project nic-cage-snacks-legacy"
  },
  "dependencies": {
    "animejs": "^3.2.1",
    "underscore": "^1.13.6"
  },
  "devDependencies": {
    "firebase-tools": "^13.35.1",
    "vite": "^5.4.10"
  }
}
